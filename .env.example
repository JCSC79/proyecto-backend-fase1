# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your own values.
#   cp .env.example .env
#
# NEVER commit .env to version control — it is listed in .gitignore.
# =============================================================================

# --- JWT -------------------------------------------------------------------
# Secret used to sign and verify JWT tokens.
# Use any random string of at least 32 characters.
# Example (do not use this exact value in production):
#   openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_secret_32chars_minimum

# --- PostgreSQL (API) -------------------------------------------------------
# DB_HOST: use "db" when running inside Docker Compose,
#          use "127.0.0.1" when running the API locally outside Docker.
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=tasks_db

# --- PostgreSQL (Docker Compose initialisation) ----------------------------
# These must match DB_USER / DB_PASSWORD / DB_NAME above.
# Docker uses them to create the database on first start.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tasks_db

# --- RabbitMQ --------------------------------------------------------------
# RABBITMQ_URL: use "rabbitmq" as hostname inside Docker Compose,
#               use "localhost" when running locally.
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change_me
RABBITMQ_URL=amqp://admin:change_me@rabbitmq:5672
